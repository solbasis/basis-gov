rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Realm / governance config ──────────────────────────────────────────────
    // Public read always.
    // Mainnet doc ('gov') — require auth to write (prevents unauthenticated overwrite of realm PKs).
    // Dev/test docs ('gov-devnet', 'gov-testnet') — fully open for local dev.
    match /config/gov {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    match /config/{docId} {
      allow read:  if true;
      allow write: if true; // devnet/testnet docs — open for local dev
    }

    // ── Proposal metadata (mainnet) ────────────────────────────────────────────
    // Public read. Create/update require auth — prevents unauthenticated spam/corruption.
    // Delete disabled — proposals are permanent record.
    match /proposals-meta/{docId} {
      allow read:           if true;
      allow create, update: if request.auth != null;
      allow delete:         if false;
    }

    // ── Proposal metadata (devnet) ────────────────────────────────────────────
    match /proposals-meta-devnet/{docId} {
      allow read, write: if true;
    }

    // ── Proposal metadata (testnet) ───────────────────────────────────────────
    match /proposals-meta-testnet/{docId} {
      allow read, write: if true;
    }

    // ── Default: deny everything not explicitly matched ────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
