# basis-gov environment variables
# Copy to .env (mainnet) or .env.devnet (devnet) and fill in your values

# Network mode
VITE_NETWORK=mainnet

# Helius RPC endpoint (get key at helius.dev)
VITE_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY_HERE
VITE_MAINNET_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY_HERE

# reCAPTCHA v3 site key (get at google.com/recaptcha)
VITE_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY_HERE

# Firebase (get from Firebase Console > Project Settings > Your apps)
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID
